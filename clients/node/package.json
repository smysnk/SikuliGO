{
  "name": "@sikuligo/sikuligo",
  "version": "0.1.4",
  "description": "SikuliGO Node.js SDK with local sikuligrpc launcher",
  "keywords": [
    "sikuli",
    "sikulix",
    "sikuligo",
    "automation",
    "testing",
    "recorder",
    "replay",
    "visual",
    "desktop",
    "gui",
    "screen",
    "image",
    "pattern",
    "scripting",
    "e2e",
    "blackbox",
    "bot",
    "rpa",
    "robot framework"
  ],
  "license": "MIT",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "sikuligo-doctor": "dist/src/doctor.js"
  },
  "files": [
    "dist",
    "generated",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build:binaries": "bash ../../scripts/clients/build-node-binaries.sh",
    "build": "bash ../../scripts/clients/generate-node-stubs.sh && tsc -p tsconfig.json",
    "prepack": "npm run clean && npm run build",
    "doctor": "node dist/src/doctor.js",
    "example:find": "tsx examples/find.ts",
    "example:click": "tsx examples/click.ts",
    "example:ocr": "tsx examples/ocr.ts",
    "example:input": "tsx examples/input.ts",
    "example:app": "tsx examples/app.ts",
    "example:user-flow": "tsx examples/user-flow.ts"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.0",
    "@grpc/proto-loader": "^0.8.0",
    "@sikuligo/bin-darwin-arm64": "0.1.4",
    "@sikuligo/bin-darwin-x64": "0.1.4",
    "@sikuligo/bin-linux-x64": "0.1.4",
    "@sikuligo/bin-win32-x64": "0.1.4"
  },
  "devDependencies": {
    "grpc-tools": "^1.13.0",
    "grpc_tools_node_protoc_ts": "^5.3.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
