{
  "name": "sikuli-go-monorepo",
  "private": true,
  "packageManager": "yarn@4.6.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -pt run build",
    "test": "yarn workspaces foreach -pt run test",
    "test:station": "npx --yes @test-station/cli@0.2.19 run --config ./test-station.config.mjs --no-coverage",
    "test:station:coverage": "npx --yes @test-station/cli@0.2.19 run --config ./test-station.config.mjs --coverage",
    "dev:ide": "bash ./scripts/editor/dev-ide.sh",
    "dev:editor": "yarn workspace @sikuligo/editor dev",
    "dev:api-electron": "yarn workspace @sikuligo/api-electron dev",
    "api:build": "yarn workspace @sikuligo/api build",
    "api:test": "yarn workspace @sikuligo/api test"
  }
}
